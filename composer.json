{
    "name": "apermo/classic-to-gutenberg-addons",
    "description": "Niche converters for classic-to-gutenberg: page builders, third-party plugins.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "gutenberg",
        "migration",
        "blocks",
        "page-builder",
        "visual-composer"
    ],
    "authors": [
        {
            "name": "Christoph Daum",
            "email": "me@christoph-daum.de"
        }
    ],
    "support": {
        "issues": "https://github.com/apermo/classic-to-gutenberg-addons/issues",
        "source": "https://github.com/apermo/classic-to-gutenberg-addons"
    },
    "require": {
        "php": ">=8.2",
        "apermo/classic-to-gutenberg": "^0.4"
    },
    "require-dev": {
        "apermo/apermo-coding-standards": "^2.0",
        "apermo/phpstan-wordpress-rules": "^0.2",
        "brain/monkey": "^2.6",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "yoast/phpunit-polyfills": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Apermo\\ClassicToGutenbergAddons\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apermo\\ClassicToGutenbergAddons\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "cs:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
